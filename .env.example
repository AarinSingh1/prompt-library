# Database — update with your local PostgreSQL credentials
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promptlibrary?schema=public"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth — create at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
